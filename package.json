{
  "name": "browser-explorer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "doctor:dev": "node scripts/dev-doctor.mjs",
    "setup:hooks": "node scripts/setup-git-hooks.mjs",
    "prepush:check": "node scripts/git-pre-push.mjs",
    "commitmsg:check": "node scripts/validate-commit-message.mjs",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "qa:mobile": "npm run build && node scripts/mobile-qa-signoff.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "perf:budget": "npm run build && node scripts/perf-budget-report.mjs",
    "evidence:release": "node scripts/release-evidence.mjs",
    "launch:check": "node scripts/launch-check.mjs",
    "ci:check": "npm run lint && npm run build",
    "preflight:prod": "node scripts/prod-preflight.mjs",
    "preflight:prod:strict": "node scripts/prod-preflight.mjs --strict"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gsap/react": "^2.1.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@studio-freight/lenis": "^1.0.42",
    "@supabase/supabase-js": "^2.98.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.0",
    "gsap": "^3.14.2",
    "lenis": "^1.3.17",
    "lucide-react": "^0.576.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
